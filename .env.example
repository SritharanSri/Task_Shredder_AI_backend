BOT_TOKEN=your_telegram_bot_token_here
WEBAPP_URL=https://task-shredder-ai-frontend.vercel.app
PORT=3000

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# Supabase — get these from: https://supabase.com/dashboard/project/_/settings/api
# NOTE: For production, use the service_role key here (bypasses RLS) — keep it secret!
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Optional: set WEBHOOK_URL for production webhook mode
# WEBHOOK_URL=https://your-backend-server.com
